# Required: UKHO Admiralty API key (free Discovery tier)
# Sign up at https://admiraltyapi.portal.azure-api.net
ADMIRALTY_API_KEY=your-api-key-here

# Required: Tidbyt device ID and API token
# Find in Tidbyt mobile app: Settings > Get API key
TIDBYT_DEVICE_ID=your-device-id
TIDBYT_API_TOKEN=your-tidbyt-api-token

# Optional: UKHO station ID (default: 0020 = Salcombe)
# Find station IDs at https://easytide.admiralty.co.uk
STATION_ID=0020

# Optional: Push interval for systemd timer (default: 15min)
PUSH_INTERVAL=15min
