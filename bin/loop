#!/usr/bin/env ruby
# frozen_string_literal: true

require "time"
require_relative "../lib/ukho_client"
require_relative "../lib/tide_calculator"
require_relative "../lib/renderer"
require_relative "../lib/open_meteo_client"
require_relative "../lib/marine_renderer"
require_relative "../lib/tidbyt_push"

$stdout.sync = true

module App
  STATION_ID = ENV.fetch("STATION_ID", "0020")
  INTERVAL   = Integer(ENV.fetch("PUSH_INTERVAL_SECONDS", 900))

  module_function

  def run
    log "Starting with station_id=#{STATION_ID} interval=#{INTERVAL}s"

    loop do
      tick
      log "Sleeping #{INTERVAL}s..."
      sleep INTERVAL
    end
  end

  def tick
    station = fetch_station
    push_tide_screen(station)
    push_marine_screen(station)
  rescue => e
    log "ERROR: #{e.class}: #{e.message}"
    log e.backtrace.first(5).map { |l| "  #{l}" }.join("\n")
  end

  def fetch_station
    log "Fetching station info..."
    station = ukho_client.station_info(STATION_ID)
    log "Station: #{station[:name]} (#{station[:latitude]}, #{station[:longitude]})"
    station
  end

  def push_tide_screen(station)
    log "Fetching tidal events..."
    events = ukho_client.tidal_events(STATION_ID)
    log "Got #{events.length} events"

    now = Time.now.utc
    calculator = TideCalculator.new(events)

    log_tide_event("high", calculator.next_high(now))
    log_tide_event("low",  calculator.next_low(now))

    webp = Renderer.new(station[:name], calculator, now: now).to_webp
    log "Rendered tide image (#{webp.bytesize} bytes)"

    tidbyt.push(webp, installation_id: "ukhotides")
    log "Pushed tide screen"
  end

  def push_marine_screen(station)
    log "Fetching marine weather..."
    meteo = OpenMeteoClient.new(latitude: station[:latitude], longitude: station[:longitude])

    marine = meteo.current_marine
    wind   = meteo.current_wind
    log "Wind: #{wind[:speed_kn]&.round}kn gusts #{wind[:gusts_kn]&.round}kn dir #{wind[:direction]}°"
    log "Swell: #{marine[:swell_height]}m #{marine[:swell_period]}s dir #{marine[:swell_direction]}°"
    log "Waves: #{marine[:wave_height]}m"

    webp = MarineRenderer.new(marine: marine, wind: wind).to_webp
    log "Rendered marine image (#{webp.bytesize} bytes)"

    tidbyt.push(webp, installation_id: "ukhotidesmarine")
    log "Pushed marine screen"
  end

  def ukho_client
    @ukho_client ||= UkhoClient.new(ENV.fetch("ADMIRALTY_API_KEY"))
  end

  def tidbyt
    @tidbyt ||= TidbytPush.new(
      device_id: ENV.fetch("TIDBYT_DEVICE_ID"),
      api_token: ENV.fetch("TIDBYT_API_TOKEN"),
    )
  end

  def log_tide_event(label, event)
    log "Next #{label}: #{event[:time]} #{event[:height]}m" if event
  end

  def log(message)
    puts "[ukho-tides] #{message}"
  end
end

App.run
